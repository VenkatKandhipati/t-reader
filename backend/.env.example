# Connection pooler (recommended for serverless / Fly.io)
# Get from Supabase: Project Settings → Database → Connection string → "Transaction"
# Replace with SQLAlchemy's asyncpg URL form:
DATABASE_URL=postgresql+asyncpg://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Project Settings → API → "JWT Secret"
SUPABASE_JWT_SECRET=replace-me

# Optional overrides
SUPABASE_JWT_AUDIENCE=authenticated
ENVIRONMENT=prod
CORS_ORIGINS=https://kathalu.pages.dev,http://localhost:8000,http://localhost:5500
